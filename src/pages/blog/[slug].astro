---
import { posts, getPostBySlug } from '../../data/posts';
import MainLayout from '../../layouts/MainLayout.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/blog');
}

const otherPosts = posts.filter((p) => p.slug !== slug).slice(0, 3);

const authorBio: Record<string, string> = {
  Ina: 'Co-fundadora de Girlas. Surfista, viajera compulsiva y creyente de que los mejores planes son los que se arman de última.',
  Valu: 'Co-fundadora de Girlas. Apasionada del trekking, la fotografía de viaje y los destinos que te cambian algo adentro.',
};
---

<MainLayout
  title={`${post.title} — Blog Girlas`}
  description={post.excerpt}
  image={post.image}
>

  <!-- ── HERO ───────────────────────────────────────────────────── -->
  <div class="relative overflow-hidden" style="min-height: 480px;">
    <img
      src={post.image}
      alt={post.title}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)] via-[var(--color-charcoal)]/60 to-transparent" />

    <div class="relative container-girlas pt-40 pb-14">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-5">
          <a
            href="/blog"
            class="flex items-center gap-1.5 text-white/60 text-sm hover:text-white transition-colors"
            aria-label="Volver al blog"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Blog
          </a>
          <span class="text-white/30" aria-hidden="true">/</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-coral)] text-white text-xs font-semibold">
            {post.category}
          </span>
        </div>

        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-5">
          {post.title}
        </h1>

        <div class="flex items-center flex-wrap gap-x-5 gap-y-2 text-white/65 text-sm">
          <span class="flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="font-medium text-white">{post.author}</span>
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <time datetime={post.dateISO}>{post.date}</time>
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {post.readTime} de lectura
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ARTICLE BODY ───────────────────────────────────────────── -->
  <div class="bg-white">
    <div class="container-girlas py-14 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12 xl:gap-16">

        <!-- Content -->
        <article>
          <p class="text-lg text-[var(--color-charcoal-mid)] leading-relaxed mb-10 pb-10 border-b border-[var(--color-cream-dark)] font-medium">
            {post.excerpt}
          </p>

          <div class="prose-girlas" set:html={post.content} />

          <!-- Author card -->
          <div class="mt-12 pt-10 border-t border-[var(--color-cream-dark)]">
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-[var(--color-cream-dark)]">
              <div class="w-14 h-14 rounded-full bg-[var(--color-coral)]/20 flex items-center justify-center flex-shrink-0 text-xl font-bold text-[var(--color-coral)] font-display">
                {post.author[0]}
              </div>
              <div>
                <p class="font-semibold text-[var(--color-charcoal)] mb-1">{post.author} — Co-fundadora de Girlas</p>
                <p class="text-[var(--color-charcoal-mid)] text-sm leading-relaxed">{authorBio[post.author]}</p>
              </div>
            </div>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:pt-2">
          <div class="sticky top-24 flex flex-col gap-6">

            <!-- Share -->
            <div class="bg-[var(--color-cream-dark)] rounded-2xl p-5">
              <h3 class="font-display font-semibold text-[var(--color-charcoal)] text-sm uppercase tracking-wide mb-4">Compartir</h3>
              <div class="flex flex-col gap-2">
                <a
                  href={`https://wa.me/?text=${encodeURIComponent(post.title + ' — ' + Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-white text-[var(--color-charcoal)] text-sm font-medium hover:bg-[var(--color-coral)] hover:text-white transition-all"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                  Compartir por WhatsApp
                </a>
                <a
                  href={`https://www.instagram.com/girlas.ar`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-white text-[var(--color-charcoal)] text-sm font-medium hover:bg-[var(--color-coral)] hover:text-white transition-all"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="m16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  Seguinos en Instagram
                </a>
              </div>
            </div>

            <!-- CTA -->
            <div class="bg-[var(--color-coral)] rounded-2xl p-5 text-white">
              <h3 class="font-display font-bold text-lg mb-2">¿Te animás a viajar?</h3>
              <p class="text-white/80 text-sm leading-relaxed mb-4">Sumate a la próxima experiencia Girlas. Preguntá por disponibilidad.</p>
              <a
                href="https://wa.me/5492944675892"
                target="_blank"
                rel="noopener noreferrer"
                class="block text-center py-2.5 px-4 rounded-xl bg-white text-[var(--color-coral)] text-sm font-semibold hover:bg-[var(--color-cream)] transition-colors"
              >
                Consultar por WhatsApp
              </a>
            </div>

          </div>
        </aside>

      </div>
    </div>
  </div>

  <!-- ── MORE POSTS ─────────────────────────────────────────────── -->
  {otherPosts.length > 0 && (
    <section class="section-padding bg-[var(--color-cream-dark)]">
      <div class="container-girlas">
        <h2 class="font-display text-3xl font-bold text-[var(--color-charcoal)] mb-8">Más artículos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherPosts.map((p) => (
            <a
              href={`/blog/${p.slug}`}
              class="group flex flex-col rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] hover:-translate-y-1 transition-all duration-300"
            >
              <div class="relative overflow-hidden aspect-video">
                <img
                  src={p.image}
                  alt={p.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <span class="text-[var(--color-coral)] text-xs font-semibold uppercase tracking-widest mb-2 block">
                  {p.category} · {p.readTime}
                </span>
                <h3 class="font-display text-lg font-semibold text-[var(--color-charcoal)] mb-2 leading-snug group-hover:text-[var(--color-coral)] transition-colors flex-1">
                  {p.title}
                </h3>
                <div class="flex items-center gap-2 text-xs text-[var(--color-charcoal-mid)] pt-4 border-t border-[var(--color-cream-dark)] mt-auto">
                  <span class="font-medium">{p.author}</span>
                  <span aria-hidden="true">·</span>
                  <span>{p.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-[var(--color-coral)] text-[var(--color-coral)] font-semibold text-sm hover:bg-[var(--color-coral)] hover:text-white transition-all">
            Ver todos los artículos
          </a>
        </div>
      </div>
    </section>
  )}

  <NewsletterSection variant="coral" />

</MainLayout>

<style>
  .prose-girlas {
    color: var(--color-charcoal);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose-girlas h2 {
    font-family: var(--font-display, 'Ojuju', sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose-girlas p {
    margin-bottom: 1.25rem;
    color: var(--color-charcoal-mid);
  }

  .prose-girlas strong {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  .prose-girlas ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .prose-girlas ul li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--color-charcoal-mid);
  }

  .prose-girlas ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-coral);
  }

  .prose-girlas hr {
    border: none;
    border-top: 1px solid var(--color-cream-dark);
    margin: 2.5rem 0;
  }
</style>
