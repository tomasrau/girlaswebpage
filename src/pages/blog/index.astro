---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';
import TestimonialCard from '../../components/ui/TestimonialCard.astro';
import { testimonials, getMetrics } from '../../data/testimonials';
import { pastDestinations } from '../../data/trips';
import { posts } from '../../data/posts';

const metrics  = getMetrics(testimonials);
const hasReviews = testimonials.length > 0;
const npsSign  = metrics.npsScore >= 0 ? '+' : '';
const sorted   = [...testimonials].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const APPS_SCRIPT_URL = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<MainLayout
  title="Blog & Reseñas — Girlas"
  description="Artículos de viaje, guías de destinos y reseñas reales de viajeras de la comunidad Girlas."
>

  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <div class="bg-[var(--color-cream-dark)] pt-32 pb-10 border-b border-[var(--color-cream-dark)]">
    <div class="container-girlas">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">Comunidad</span>
      </div>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-[var(--color-charcoal)] mb-4">
        Historias & <em class="text-gradient-coral not-italic">Reseñas</em>
      </h1>
      <p class="text-[var(--color-charcoal-mid)] text-lg max-w-xl leading-relaxed">
        Inspiración, consejos de viaje y experiencias reales de la comunidad Girlas.
      </p>
      <div class="flex items-center gap-6 mt-5 text-sm text-[var(--color-charcoal-mid)]">
        <span class="flex items-center gap-1.5">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          {posts.length} artículos
        </span>
        {hasReviews && (
          <span class="flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {metrics.total} reseña{metrics.total !== 1 ? 's' : ''} · {metrics.avgStars}★ promedio
          </span>
        )}
      </div>
    </div>
  </div>

  <!-- ── STICKY TAB BAR ─────────────────────────────────────────── -->
  <div id="tab-bar" class="bg-white border-b border-[var(--color-cream-dark)] sticky top-0 z-40 transition-shadow duration-200">
    <div class="container-girlas">
      <div role="tablist" aria-label="Secciones del blog" class="flex gap-2 py-3">

        <button
          id="tab-articulos"
          role="tab"
          aria-selected="true"
          aria-controls="panel-articulos"
          data-tab="articulos"
          class="tab-btn active flex items-center gap-2 flex-1 sm:flex-none justify-center sm:justify-start px-5 py-2.5 rounded-full text-sm font-semibold transition-all whitespace-nowrap"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Artículos
          <span class="tab-count">{posts.length}</span>
        </button>

        <button
          id="tab-resenas"
          role="tab"
          aria-selected="false"
          aria-controls="panel-resenas"
          data-tab="resenas"
          class="tab-btn flex items-center gap-2 flex-1 sm:flex-none justify-center sm:justify-start px-5 py-2.5 rounded-full text-sm font-semibold transition-all whitespace-nowrap"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Reseñas
          {hasReviews && <span class="tab-count">{metrics.total}</span>}
        </button>

      </div>
    </div>
  </div>

  <!-- ── PANEL: ARTÍCULOS ──────────────────────────────────────── -->
  <div id="panel-articulos" role="tabpanel" aria-labelledby="tab-articulos" class="tab-panel">
    <section class="section-padding">
      <div class="container-girlas">

        {posts[0] && (
          <a
            href={`/blog/${posts[0].slug}`}
            class="group block mb-10 rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] transition-all duration-300"
          >
            <div class="grid grid-cols-1 lg:grid-cols-2">
              <div class="relative overflow-hidden aspect-video lg:aspect-auto" style="min-height:260px">
                <img
                  src={posts[0].image}
                  alt={posts[0].title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="eager"
                />
                <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[var(--color-coral)] text-white text-xs font-semibold">
                  Destacado
                </span>
              </div>
              <div class="p-7 lg:p-10 flex flex-col justify-center">
                <span class="text-[var(--color-coral)] text-xs font-semibold uppercase tracking-widest mb-3">
                  {posts[0].category} · {posts[0].readTime} de lectura
                </span>
                <h2 class="font-display text-2xl lg:text-3xl font-bold text-[var(--color-charcoal)] mb-3 group-hover:text-[var(--color-coral)] transition-colors leading-snug">
                  {posts[0].title}
                </h2>
                <p class="text-[var(--color-charcoal-mid)] leading-relaxed mb-5 text-sm lg:text-base line-clamp-3">
                  {posts[0].excerpt}
                </p>
                <div class="flex items-center gap-3 text-sm text-[var(--color-charcoal-mid)]">
                  <span class="font-medium text-[var(--color-charcoal)]">{posts[0].author}</span>
                  <span aria-hidden="true">·</span>
                  <span>{posts[0].date}</span>
                </div>
              </div>
            </div>
          </a>
        )}

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.slice(1).map(({ slug, title, excerpt, image, date, category, readTime, author }) => (
            <a
              href={`/blog/${slug}`}
              class="group flex flex-col rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] hover:-translate-y-1 transition-all duration-300"
            >
              <div class="relative overflow-hidden aspect-video">
                <img
                  src={image}
                  alt={title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <span class="text-[var(--color-coral)] text-xs font-semibold uppercase tracking-widest mb-2 block">
                  {category} · {readTime}
                </span>
                <h3 class="font-display text-lg font-semibold text-[var(--color-charcoal)] mb-2 leading-snug group-hover:text-[var(--color-coral)] transition-colors flex-1">
                  {title}
                </h3>
                <p class="text-[var(--color-charcoal-mid)] text-sm leading-relaxed mb-4 line-clamp-3">
                  {excerpt}
                </p>
                <div class="flex items-center gap-2 text-xs text-[var(--color-charcoal-mid)] pt-4 border-t border-[var(--color-cream-dark)] mt-auto">
                  <span class="font-medium">{author}</span>
                  <span aria-hidden="true">·</span>
                  <span>{date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>
  </div>

  <!-- ── PANEL: RESEÑAS ─────────────────────────────────────────── -->
  <div id="panel-resenas" role="tabpanel" aria-labelledby="tab-resenas" class="tab-panel" hidden>
    <section class="section-padding">
      <div class="container-girlas">

        {hasReviews ? (
          <>
            <!-- Metrics -->
            <div class="grid grid-cols-3 gap-3 sm:gap-5 mb-12 max-w-lg mx-auto">
              <div class="text-center bg-white rounded-2xl p-4 sm:p-6 shadow-[var(--shadow-card)]">
                <div class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-gold)] leading-none mb-1">
                  {metrics.avgStars}
                </div>
                <div class="flex justify-center gap-0.5 my-1.5" aria-hidden="true">
                  {Array.from({ length: 5 }, (_, i) => (
                    <svg width="11" height="11" viewBox="0 0 24 24"
                      fill={i < Math.round(metrics.avgStars) ? 'var(--color-gold)' : 'none'}
                      stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  ))}
                </div>
                <p class="text-[var(--color-charcoal-mid)] text-[0.65rem] sm:text-xs leading-snug">Calificación</p>
              </div>
              <div class="text-center bg-white rounded-2xl p-4 sm:p-6 shadow-[var(--shadow-card)]">
                <div class={`font-display text-3xl sm:text-4xl font-bold leading-none mb-1 ${metrics.npsScore >= 0 ? 'text-[var(--color-teal)]' : 'text-[var(--color-coral)]'}`}>
                  {npsSign}{metrics.npsScore}
                </div>
                <p class="text-[var(--color-charcoal-mid)] text-[0.65rem] sm:text-xs mt-3 leading-snug">¿Lo recomendarías?</p>
              </div>
              <div class="text-center bg-white rounded-2xl p-4 sm:p-6 shadow-[var(--shadow-card)]">
                <div class="font-display text-2xl sm:text-4xl font-bold text-[var(--color-coral)] leading-none mb-1 tabular-nums">
                  {metrics.wouldReturnPct}%
                </div>
                <p class="text-[var(--color-charcoal-mid)] text-[0.65rem] sm:text-xs mt-3 leading-snug">Volvería</p>
              </div>
            </div>

            <!-- Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
              {sorted.map((t) => (
                <TestimonialCard
                  name={t.name}
                  instagramHandle={t.instagramHandle}
                  stars={t.stars}
                  nps={t.nps}
                  wouldReturn={t.wouldReturn}
                  text={t.text}
                  trip={t.destination}
                  date={t.date}
                />
              ))}
            </div>
          </>
        ) : (
          <div class="text-center py-16 mb-12">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[var(--color-coral)]/10 mb-6" aria-hidden="true">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-coral)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-[var(--color-charcoal)] mb-3">
              Las primeras reseñas están en camino
            </h3>
            <p class="text-[var(--color-charcoal-mid)] max-w-sm mx-auto leading-relaxed">
              Sé parte de la comunidad y contá tu experiencia. Solo tardás 2 minutos.
            </p>
          </div>
        )}

        <!-- CTA -->
        <div class="text-center border-t border-[var(--color-cream-dark)] pt-10">
          <p class="text-[var(--color-charcoal-mid)] text-sm mb-4">
            {hasReviews ? '¿Ya viajaste con Girlas? Tu historia puede inspirar a otras.' : '¿Ya viajaste con nosotras? Contanos.'}
          </p>
          <button
            id="open-review-modal"
            type="button"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[var(--color-coral)] text-white font-semibold text-base hover:bg-[var(--color-coral-dark)] shadow-lg hover:shadow-xl transition-all active:scale-95"
            aria-haspopup="dialog"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Contar mi experiencia
          </button>
        </div>

      </div>
    </section>
  </div>

  <NewsletterSection variant="coral" />

</MainLayout>

<!-- ── REVIEW MODAL ──────────────────────────────────────────────── -->
<dialog id="review-dialog" aria-labelledby="dialog-title" aria-modal="true" class="review-dialog">
  <div class="dialog-backdrop" id="dialog-backdrop" aria-hidden="true"></div>
  <div class="dialog-panel" role="document">

    <div class="dialog-header">
      <div>
        <h2 id="dialog-title" class="font-display text-2xl font-bold text-[var(--color-charcoal)]">
          Contá tu experiencia
        </h2>
        <p class="text-[var(--color-charcoal-mid)] text-sm mt-1">Tu reseña ayuda a otras mujeres a animarse a viajar.</p>
      </div>
      <button id="close-review-modal" type="button" aria-label="Cerrar" class="close-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <form id="review-form" novalidate class="dialog-form">
      <input type="hidden" name="stars"       id="hidden-stars" />
      <input type="hidden" name="nps"         id="hidden-nps" />
      <input type="hidden" name="wouldReturn" id="hidden-would-return" />

      <fieldset class="form-group">
        <legend class="form-legend">Sobre vos</legend>
        <div class="form-row">
          <div class="form-field">
            <label for="field-name" class="form-label">
              Tu nombre <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
            </label>
            <input type="text" id="field-name" name="name" autocomplete="given-name" placeholder="Ej: María G." required class="form-input" />
          </div>
          <div class="form-field">
            <label for="field-instagram" class="form-label">
              Tu @instagram <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
            </label>
            <div class="input-prefix-wrap">
              <span class="input-prefix" aria-hidden="true">@</span>
              <input type="text" id="field-instagram" name="instagram" autocomplete="username" placeholder="tuinstagram" required class="form-input with-prefix" />
            </div>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-group">
        <legend class="form-legend">Tu viaje</legend>
        <div class="form-field">
          <label for="field-destination" class="form-label">
            ¿A qué destino viajaste? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </label>
          <select id="field-destination" name="destination" required class="form-input">
            <option value="" disabled selected>Seleccioná un destino</option>
            {pastDestinations.map(d => (
              <option value={d}>{d}</option>
            ))}
            <option value="Otro destino">Otro destino</option>
          </select>
        </div>
        <div class="form-field">
          <span class="form-label" id="stars-label">
            Tu calificación <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div class="stars-picker" role="radiogroup" aria-labelledby="stars-label" aria-required="true">
            {[1,2,3,4,5].map(n => (
              <button type="button" data-value={n} class="star-btn" aria-label={`${n} estrella${n > 1 ? 's' : ''}`} aria-pressed="false">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </button>
            ))}
          </div>
          <p class="star-hint" id="stars-hint" aria-live="polite"></p>
        </div>
      </fieldset>

      <fieldset class="form-group">
        <legend class="form-legend">Tu opinión</legend>
        <div class="form-field">
          <span class="form-label" id="nps-label">
            ¿Cuánto recomendarías Girlas? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div class="nps-picker" role="radiogroup" aria-labelledby="nps-label" aria-required="true">
            {Array.from({ length: 11 }, (_, i) => (
              <button type="button" data-value={i} class="nps-btn" aria-label={`${i} de 10`} aria-pressed="false">{i}</button>
            ))}
          </div>
          <div class="nps-labels" aria-hidden="true">
            <span>No la recomendaría</span>
            <span>La recomendaría muchísimo</span>
          </div>
        </div>
        <div class="form-field">
          <span class="form-label" id="return-label">
            ¿Volverías a viajar con Girlas? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div class="return-picker" role="radiogroup" aria-labelledby="return-label" aria-required="true">
            <button type="button" data-value="si"     class="return-btn" aria-pressed="false">Sí, seguro</button>
            <button type="button" data-value="talvez" class="return-btn" aria-pressed="false">Tal vez</button>
            <button type="button" data-value="no"     class="return-btn" aria-pressed="false">Todavía no</button>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-group">
        <legend class="form-legend">Tu historia</legend>
        <div class="form-field">
          <label for="field-text" class="form-label">
            Contanos tu experiencia <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </label>
          <textarea
            id="field-text" name="review" rows="4" required minlength="30"
            placeholder="¿Qué fue lo que más te gustó? ¿Cómo fue la experiencia en el grupo? ¿Qué le dirías a alguien que está por anotarse?"
            class="form-input resize-none"
          ></textarea>
          <p class="text-xs text-[var(--color-charcoal-mid)] mt-1 text-right">
            <span id="char-count">0</span> caracteres (mín. 30)
          </p>
        </div>
      </fieldset>

      <div class="form-submit-area">
        <p class="text-xs text-[var(--color-charcoal-mid)] text-center max-w-sm mx-auto">
          Al enviar aceptás que tu nombre e Instagram puedan aparecer públicamente en el sitio de Girlas.
        </p>
        <button type="submit" id="submit-btn" class="submit-btn">
          <span class="submit-label">Enviar mi reseña</span>
          <span class="submit-spinner" aria-hidden="true"></span>
        </button>
        <p id="form-error" class="form-error" role="alert" aria-live="assertive"></p>
      </div>
    </form>

    <div id="review-success" class="review-success" aria-live="polite" hidden>
      <div class="success-icon" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/>
        </svg>
      </div>
      <h3 class="font-display text-2xl font-bold text-[var(--color-charcoal)] text-center">¡Gracias por compartir!</h3>
      <p class="text-[var(--color-charcoal-mid)] text-center leading-relaxed">
        Tu reseña ya es parte de la comunidad Girlas y va a aparecer en el sitio en unos minutos.
      </p>
      <button type="button" id="close-success" class="submit-btn" style="background:var(--color-teal)">Cerrar</button>
    </div>

  </div>
</dialog>

<!-- ── STYLES ──────────────────────────────────────────────────────── -->
<style>
  /* Tabs */
  .tab-btn {
    color: var(--color-charcoal-mid);
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .tab-btn:hover {
    color: var(--color-charcoal);
    background: var(--color-cream-dark);
  }
  .tab-btn.active {
    background: var(--color-coral);
    color: #fff;
  }
  .tab-btn:focus-visible {
    outline: 2px solid var(--color-coral);
    outline-offset: 2px;
  }
  .tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.3rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(255,255,255,0.25);
    color: inherit;
  }
  .tab-btn:not(.active) .tab-count {
    background: var(--color-cream-dark);
    color: var(--color-charcoal-mid);
  }

  /* Tab panels */
  .tab-panel { display: none; }
  .tab-panel:not([hidden]).active {
    display: block;
    animation: tabIn 0.2s ease forwards;
  }
  @keyframes tabIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Tab bar shadow on scroll */
  #tab-bar.scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.07); }

  /* ── Dialog ── */
  .review-dialog {
    position: fixed; inset: 0; margin: 0; padding: 0;
    width: 100%; max-width: 100%; height: 100%; max-height: 100%;
    border: none; background: transparent; overflow: hidden;
    display: none; align-items: center; justify-content: center; z-index: 100;
  }
  .review-dialog[open] { display: flex; }

  .dialog-backdrop {
    position: absolute; inset: 0;
    background: rgba(38,35,34,0.6);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .dialog-panel {
    position: relative; z-index: 1;
    background: #fff; border-radius: 1.5rem;
    width: min(560px, calc(100vw - 2rem));
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
    display: flex; flex-direction: column;
    box-shadow: 0 24px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
    overscroll-behavior: contain;
  }

  .dialog-header {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 1rem;
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--color-cream-dark);
    position: sticky; top: 0; background: #fff; z-index: 2;
    border-radius: 1.5rem 1.5rem 0 0;
  }

  .close-btn {
    width: 2.25rem; height: 2.25rem; border-radius: 9999px;
