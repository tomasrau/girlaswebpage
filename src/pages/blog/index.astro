    cursor: pointer; transition: all 0.15s; text-align: center;
  }
  .return-btn:hover { border-color: var(--color-coral); color: var(--color-coral); }
  .return-btn[aria-pressed="true"] { background: var(--color-coral); border-color: var(--color-coral); color: #fff; }
  .return-btn[data-value="si"][aria-pressed="true"] { background: var(--color-teal); border-color: var(--color-teal); }
  .return-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 2px; }

