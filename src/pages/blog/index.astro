---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';

const posts = [
  {
    slug: 'viajar-sola-primer-vez',
    title: '10 consejos para viajar sola por primera vez',
    excerpt: 'Todo lo que necesitás saber antes de tu primer viaje en soledad. Desde la elección del destino hasta cómo mantenerte conectada con tu familia.',
    image: '/images/blog/viajar-sola.jpg',
    date: '15 de mayo, 2025',
    category: 'Consejos',
    readTime: '5 min',
    author: 'Sofía Ramírez',
  },
  {
    slug: 'mejores-destinos-argentina',
    title: 'Los 7 destinos imperdibles de Argentina para mujeres viajeras',
    excerpt: 'De la Patagonia al Norte argentino: estos son los lugares que toda mujer viajera debería conocer en su propio país.',
    image: '/images/blog/argentina.jpg',
    date: '3 de abril, 2025',
    category: 'Destinos',
    readTime: '8 min',
    author: 'Lucía Fernández',
  },
  {
    slug: 'que-llevar-retiro-bienestar',
    title: '¿Qué llevar a un retiro de bienestar? La guía definitiva',
    excerpt: 'Ropa, accesorios, mentalidad. Todo lo que necesitás para aprovechar al máximo tu próximo retiro de yoga y meditación.',
    image: '/images/blog/retiro.jpg',
    date: '20 de marzo, 2025',
    category: 'Guías',
    readTime: '6 min',
    author: 'Martina Gómez',
  },
  {
    slug: 'machu-picchu-guia-completa',
    title: 'Machu Picchu: la guía completa para tu visita',
    excerpt: 'Cómo llegar, cuándo ir, qué ver y cómo aprovechar al máximo este lugar mágico. Todo lo que necesitás saber.',
    image: '/images/blog/peru.jpg',
    date: '8 de febrero, 2025',
    category: 'Destinos',
    readTime: '12 min',
    author: 'Sofía Ramírez',
  },
];

const categories = ['Todos', 'Consejos', 'Destinos', 'Guías', 'Experiencias'];
---

<MainLayout
  title="Blog"
  description="Consejos de viaje, guías de destinos e historias de mujeres viajeras en el blog de Girlas."
>
  <!-- Header -->
  <div class="bg-[var(--color-cream-dark)] pt-32 pb-16 border-b border-[var(--color-cream-dark)]">
    <div class="container-girlas">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">Blog</span>
      </div>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-[var(--color-charcoal)] mb-4">
        Historias & Consejos
      </h1>
      <p class="text-[var(--color-charcoal-mid)] text-xl max-w-xl mb-6">
        Inspiración, consejos prácticos y relatos de viaje del mundo Girlas.
      </p>
      <a
        href="/testimonios"
        class="inline-flex items-center gap-2 text-[var(--color-coral)] font-semibold text-sm hover:gap-3 transition-all"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Ver reseñas de viajeras
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <section class="section-padding">
    <div class="container-girlas">
      <!-- Featured post -->
      {posts[0] && (
        <a
          href={`/blog/${posts[0].slug}`}
          class="group block mb-12 rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] transition-all"
        >
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="relative overflow-hidden aspect-video lg:aspect-auto">
              <img
                src={posts[0].image}
                alt={posts[0].title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 min-h-[300px]"
                loading="eager"
              />
              <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[var(--color-coral)] text-white text-xs font-semibold">
                Destacado
              </span>
            </div>
            <div class="p-8 lg:p-10 flex flex-col justify-center">
              <span class="text-[var(--color-coral)] text-xs font-semibold uppercase tracking-widest mb-3">
                {posts[0].category} · {posts[0].readTime} de lectura
              </span>
              <h2 class="font-display text-3xl lg:text-4xl font-bold text-[var(--color-charcoal)] mb-4 group-hover:text-[var(--color-coral)] transition-colors">
                {posts[0].title}
              </h2>
              <p class="text-[var(--color-charcoal-mid)] leading-relaxed mb-6">{posts[0].excerpt}</p>
              <div class="flex items-center gap-3 text-sm text-[var(--color-charcoal-mid)]">
                <span class="font-medium text-[var(--color-charcoal)]">{posts[0].author}</span>
                <span>·</span>
                <span>{posts[0].date}</span>
              </div>
            </div>
          </div>
        </a>
      )}

      <!-- Posts grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.slice(1).map(({ slug, title, excerpt, image, date, category, readTime, author }) => (
          <a
            href={`/blog/${slug}`}
            class="group block rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] hover:-translate-y-1 transition-all"
          >
            <div class="relative overflow-hidden aspect-video">
              <img
                src={image}
                alt={title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <span class="text-[var(--color-coral)] text-xs font-semibold uppercase tracking-widest mb-2 block">
                {category} · {readTime}
              </span>
              <h3 class="font-display text-xl font-semibold text-[var(--color-charcoal)] mb-2 leading-snug group-hover:text-[var(--color-coral)] transition-colors">
                {title}
              </h3>
              <p class="text-[var(--color-charcoal-mid)] text-sm leading-relaxed mb-4 line-clamp-3">
                {excerpt}
              </p>
              <div class="flex items-center gap-2 text-xs text-[var(--color-charcoal-mid)] pt-4 border-t border-[var(--color-cream-dark)]">
                <span class="font-medium">{author}</span>
                <span>·</span>
                <span>{date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterSection variant="coral" />
</MainLayout>
