<!-- ── SCRIPTS ─────────────────────────────────────────────────────── -->
<script is:inline define:vars={{ APPS_SCRIPT_URL }}>

  // ── Tab switching ──
  const tabBtns   = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  function switchTab(id) {
    tabBtns.forEach(b => {
      const active = b.dataset.tab === id;
      b.classList.toggle('active', active);
      b.setAttribute('aria-selected', String(active));
    });
    tabPanels.forEach(p => {
      const active = p.id === `panel-${id}`;
      p.classList.toggle('active', active);
      p.hidden = !active;
    });
    history.replaceState(null, '', `#${id}`);
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    btn.addEventListener('keydown', e => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const tabs = [...tabBtns];
        const idx  = tabs.indexOf(btn);
        const next = tabs[(idx + (e.key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length];
        next.click();
        next.focus();
      }
    });
  });

  // Init tab from URL hash
  const initTab = ['articulos','resenas'].includes(location.hash.slice(1))
    ? location.hash.slice(1)
    : 'articulos';
  switchTab(initTab);

  // Tab bar shadow on scroll
  const tabBar = document.getElementById('tab-bar');
  window.addEventListener('scroll', () => {
    tabBar?.classList.toggle('scrolled', window.scrollY > 80);
  }, { passive: true });

  // ── Modal ──
  const dialog       = document.getElementById('review-dialog');
  const openBtn      = document.getElementById('open-review-modal');
  const closeBtn     = document.getElementById('close-review-modal');
  const backdrop     = document.getElementById('dialog-backdrop');
  const form         = document.getElementById('review-form');
  const successPanel = document.getElementById('review-success');
  const closeSuccess = document.getElementById('close-success');
  const submitBtn    = document.getElementById('submit-btn');
  const formError    = document.getElementById('form-error');
  const charCount    = document.getElementById('char-count');
  const textarea     = document.getElementById('field-text');
  const hiddenStars  = document.getElementById('hidden-stars');
  const hiddenNps    = document.getElementById('hidden-nps');
  const hiddenReturn = document.getElementById('hidden-would-return');

  function openDialog() {
    dialog.showModal();
    document.body.style.overflow = 'hidden';
    setTimeout(() => closeBtn?.focus(), 50);
  }
  function closeDialog() {
    dialog.close();
    document.body.style.overflow = '';
    openBtn?.focus();
  }

  openBtn?.addEventListener('click', openDialog);
  closeBtn?.addEventListener('click', closeDialog);
  closeSuccess?.addEventListener('click', closeDialog);
  backdrop?.addEventListener('click', closeDialog);
  dialog?.addEventListener('cancel', e => { e.preventDefault(); closeDialog(); });

  // Stars
  const starBtns   = document.querySelectorAll('.star-btn');
  const starHint   = document.getElementById('stars-hint');
  const starLabels = ['','Malo','Regular','Bueno','Muy bueno','Excelente'];
  let selectedStars = 0;

  starBtns.forEach(btn => {
    const val = parseInt(btn.dataset.value);
    btn.addEventListener('mouseenter', () => highlightStars(val));
    btn.addEventListener('mouseleave', () => highlightStars(selectedStars));
    btn.addEventListener('click', () => {
      selectedStars = val;
      hiddenStars.value = val;
      highlightStars(val, true);
      if (starHint) starHint.textContent = starLabels[val] || '';
    });
  });

  function highlightStars(upTo, persist = false) {
    starBtns.forEach(b => {
      const v = parseInt(b.dataset.value);
      b.querySelector('svg').setAttribute('fill', v <= upTo ? 'var(--color-gold)' : 'none');
      if (persist) b.setAttribute('aria-pressed', v <= upTo ? 'true' : 'false');
    });
  }

  // NPS
  const npsBtns = document.querySelectorAll('.nps-btn');
  npsBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      npsBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      hiddenNps.value = btn.dataset.value;
    });
  });

  // Would return
  const returnBtns = document.querySelectorAll('.return-btn');
  returnBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      returnBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      hiddenReturn.value = btn.dataset.value;
    });
  });

  // Char counter
  textarea?.addEventListener('input', () => {
    charCount.textContent = textarea.value.length;
  });

  // Validation
  function validate() {
    const name = document.getElementById('field-name').value.trim();
    const ig   = document.getElementById('field-instagram').value.trim();
    const dest = document.getElementById('field-destination').value;
    const text = textarea.value.trim();
    if (!name)              return 'Por favor ingresá tu nombre.';
    if (!ig)                return 'Tu @instagram es obligatorio para verificar la reseña.';
    if (!dest)              return 'Por favor seleccioná un destino.';
    if (!hiddenStars.value) return 'Por favor seleccioná una calificación.';
    if (!hiddenNps.value)   return 'Por favor indicá tu NPS (0-10).';
    if (!hiddenReturn.value) return '¿Volverías a viajar con Girlas?';
    if (text.length < 30)   return `Contanos un poco más (${30 - text.length} caracteres más).`;
    return null;
  }

  // Submit
  form?.addEventListener('submit', async e => {
    e.preventDefault();
    formError.textContent = '';
    const err = validate();
    if (err) { formError.textContent = err; return; }
    if (!APPS_SCRIPT_URL) {
      formError.textContent = 'El formulario no está configurado. Escribinos por WhatsApp.';
      return;
    }
    submitBtn.disabled = true;
    submitBtn.classList.add('loading');
    try {
      const payload = new URLSearchParams({
        name:        document.getElementById('field-name').value.trim(),
        instagram:   document.getElementById('field-instagram').value.trim(),
        destination: document.getElementById('field-destination').value,
        stars:       hiddenStars.value,
        nps:         hiddenNps.value,
        wouldReturn: hiddenReturn.value,
        review:      textarea.value.trim(),
      });
      const res  = await fetch(APPS_SCRIPT_URL, {
        method: 'POST', body: payload,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      });
      const body = await res.json().catch(() => ({}));
      if (body?.ok) {
        form.hidden = true;
        successPanel.hidden = false;
      } else {
        formError.textContent = body?.error || 'Hubo un error al enviar. Intentá por WhatsApp.';
        submitBtn.disabled = false;
        submitBtn.classList.remove('loading');
      }
    } catch {
      formError.textContent = 'Error de conexión. Revisá tu internet e intentá de nuevo.';
      submitBtn.disabled = false;
      submitBtn.classList.remove('loading');
    }
  });

  // Reset on close
  dialog?.addEventListener('close', () => {
    form.reset();
    form.hidden = false;
    successPanel.hidden = true;
    submitBtn.disabled = false;
    submitBtn.classList.remove('loading');
    formError.textContent = '';
    selectedStars = 0;
    hiddenStars.value = '';
    hiddenNps.value = '';
    hiddenReturn.value = '';
    if (starHint) starHint.textContent = '';
    if (charCount) charCount.textContent = '0';
    highlightStars(0);
    npsBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
    returnBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
  });
</script>
