---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';

const photos = [
  { src: '/images/gallery/01.jpg', alt: 'Trekking en la Patagonia', caption: 'Patagonia Austral', cols: 'col-span-2 row-span-2' },
  { src: '/images/gallery/02.jpg', alt: 'Atardecer en el Valle de Uco', caption: 'Mendoza' },
  { src: '/images/gallery/03.jpg', alt: 'Ciudad Amurallada de Cartagena', caption: 'Colombia' },
  { src: '/images/gallery/04.jpg', alt: 'Salinas Grandes de Jujuy', caption: 'Norte Argentino', cols: 'col-span-2' },
  { src: '/images/gallery/05.jpg', alt: 'Cataratas del Iguazú', caption: 'Misiones' },
  { src: '/images/gallery/06.jpg', alt: 'Machu Picchu al amanecer', caption: 'Perú' },
  { src: '/images/gallery/07.jpg', alt: 'Retiro de yoga en la montaña', caption: 'Retiro Mendoza' },
  { src: '/images/gallery/08.jpg', alt: 'Grupo de viajeras en Colombia', caption: 'Colombia Mágica' },
];
---

<MainLayout
  title="Galería"
  description="Mirá las fotos de nuestras experiencias de viaje. Patagonia, Colombia, Perú, Norte Argentino y más."
>
  <!-- Header -->
  <div class="bg-[var(--color-charcoal)] text-white pt-32 pb-16">
    <div class="container-girlas">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">Galería</span>
      </div>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-white mb-4">
        Momentos Girlas
      </h1>
      <p class="text-white/70 text-xl max-w-xl">
        Cada foto cuenta una historia. Estas son algunas de las aventuras que vivimos juntas.
      </p>
    </div>
  </div>

  <!-- Gallery grid -->
  <section class="section-padding">
    <div class="container-girlas">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 auto-rows-[200px]">
        {photos.map(({ src, alt, caption, cols }) => (
          <div
            class:list={[
              'relative overflow-hidden rounded-[var(--radius-card)] group cursor-pointer',
              cols || '',
            ]}
          >
            <img
              src={src}
              alt={alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <span class="text-white text-sm font-medium">{caption}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <p class="text-[var(--color-charcoal-mid)] mb-4">¿Querés ver más? Seguinos en Instagram.</p>
        <a
          href="https://instagram.com/girlas.ar"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[var(--color-charcoal)] text-white font-semibold hover:bg-[var(--color-charcoal-mid)] transition-all"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="m16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          @girlas.ar
        </a>
      </div>
    </div>
  </section>

  <NewsletterSection variant="coral" />
</MainLayout>
