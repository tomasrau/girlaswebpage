---
import MainLayout from '../../layouts/MainLayout.astro';
import TestimonialCard from '../../components/ui/TestimonialCard.astro';
import { testimonials, getMetrics } from '../../data/testimonials';

const metrics = getMetrics(testimonials);
const hasData = testimonials.length > 0;
const npsSign = metrics.npsScore >= 0 ? '+' : '';

const sortedByDate = [...testimonials].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<MainLayout
  title="Lo que dicen ellas"
  description="Reseñas reales de viajeras que eligieron Girlas. Calificaciones, NPS y experiencias en primera persona."
>

  <!-- Hero header -->
  <div class="bg-[var(--color-cream-dark)] pt-32 pb-16 border-b border-[var(--color-cream-dark)]">
    <div class="container-girlas">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">Reseñas</span>
      </div>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-[var(--color-charcoal)] mb-4">
        Lo que dicen ellas
      </h1>
      <p class="text-[var(--color-charcoal-mid)] text-xl max-w-xl">
        {hasData
          ? `${metrics.total} viajera${metrics.total !== 1 ? 's' : ''} compartió su historia. Todas las reseñas son reales y aprobadas por el equipo Girlas.`
          : 'Las primeras reseñas están en camino. Sé parte de la comunidad.'}
      </p>

      {hasData && (
        <!-- Metrics strip -->
        <div class="flex flex-wrap gap-8 mt-10">
          <div>
            <div class="font-display text-4xl font-bold text-[var(--color-gold)]">{metrics.avgStars} <span class="text-2xl">/ 5</span></div>
            <p class="text-[var(--color-charcoal-mid)] text-sm mt-1">Calificación promedio</p>
          </div>
          <div class="w-px bg-[var(--color-cream-dark)] hidden sm:block" />
          <div>
            <div class={`font-display text-4xl font-bold ${metrics.npsScore >= 0 ? 'text-[var(--color-teal)]' : 'text-[var(--color-coral)]'}`}>
              {npsSign}{metrics.npsScore}
            </div>
            <p class="text-[var(--color-charcoal-mid)] text-sm mt-1">Net Promoter Score</p>
          </div>
          <div class="w-px bg-[var(--color-cream-dark)] hidden sm:block" />
          <div>
            <div class="font-display text-4xl font-bold text-[var(--color-coral)]">{metrics.wouldReturnPct}%</div>
            <p class="text-[var(--color-charcoal-mid)] text-sm mt-1">Volvería a viajar</p>
          </div>
        </div>
      )}
    </div>
  </div>

  <section class="section-padding">
    <div class="container-girlas">

      {hasData ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedByDate.map((t) => (
            <TestimonialCard
              name={t.name}
              instagramHandle={t.instagramHandle}
              stars={t.stars}
              nps={t.nps}
              wouldReturn={t.wouldReturn}
              text={t.text}
              trip={t.destination}
              date={t.date}
            />
          ))}
        </div>
      ) : (
        <!-- Empty state -->
        <div class="text-center py-20">
          <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-[var(--color-coral)]/10 mb-8" aria-hidden="true">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--color-coral)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h2 class="font-display text-3xl font-bold text-[var(--color-charcoal)] mb-4">
            Las reseñas están en camino
          </h2>
          <p class="text-[var(--color-charcoal-mid)] text-lg max-w-md mx-auto mb-8 leading-relaxed">
            Las primeras viajeras ya están viviendo sus experiencias. Pronto sus historias van a estar acá.
          </p>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-[var(--color-coral)] text-[var(--color-coral)] font-semibold hover:bg-[var(--color-coral)] hover:text-white transition-all"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            Ver experiencias
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- CTA section -->
  <section class="section-padding bg-[var(--color-cream-dark)]">
    <div class="container-girlas text-center">
      <div class="max-w-xl mx-auto">
        <h2 class="font-display text-3xl lg:text-4xl font-bold text-[var(--color-charcoal)] mb-4">
          ¿Ya viajaste con Girlas?
        </h2>
        <p class="text-[var(--color-charcoal-mid)] text-lg leading-relaxed mb-8">
          Tu experiencia puede ayudar a otras mujeres a dar el primer paso. Compartila acá.
        </p>
        <a
          href="/#testimonials"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[var(--color-coral)] text-white font-semibold text-base hover:bg-[var(--color-coral-dark)] shadow-lg hover:shadow-xl transition-all active:scale-95"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Contar mi experiencia
        </a>
      </div>
    </div>
  </section>

</MainLayout>
