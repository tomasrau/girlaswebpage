---
import TestimonialCard from '../ui/TestimonialCard.astro';

const testimonials = [
  {
    name: 'Valentina M.',
    location: 'Buenos Aires, ARG',
    text: 'El viaje a la Patagonia con Girlas fue la experiencia más transformadora de mi vida. Las guías son increíbles, el grupo de chicas fue lo más. Ya estoy planeando el próximo.',
    rating: 5,
    trip: 'Patagonia Austral',
  },
  {
    name: 'Rocío B.',
    location: 'Córdoba, ARG',
    text: 'Nunca había viajado sola y con Girlas encontré la manera perfecta de hacerlo. Me sentí acompañada, segura y libre al mismo tiempo. Una experiencia que recomiendo a todas.',
    rating: 5,
    trip: 'Retiro en Mendoza',
  },
  {
    name: 'Camila S.',
    location: 'Rosario, ARG',
    text: 'La atención, el cuidado por los detalles, los destinos elegidos... todo es perfecto. Girlas entiende exactamente qué necesitamos las mujeres cuando viajamos.',
    rating: 5,
    trip: 'Colombia Mágica',
  },
];
---

<section class="section-padding bg-[var(--color-cream-dark)]" aria-labelledby="testimonials-title">
  <div class="container-girlas">
    <div class="text-center mb-14">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">
          Lo que dicen ellas
        </span>
        <div class="w-10 h-px bg-[var(--color-coral)]" />
      </div>
      <h2 id="testimonials-title" class="font-display text-4xl lg:text-5xl font-bold text-[var(--color-charcoal)] mb-4">
        Historias reales,<br />
        <em class="text-gradient-coral not-italic">aventuras reales</em>
      </h2>
      <p class="text-[var(--color-charcoal-mid)] text-lg max-w-xl mx-auto">
        Más de 500 mujeres ya confiaron en Girlas para sus viajes. Estas son algunas de sus historias.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <TestimonialCard {...t} />
      ))}
    </div>

    <!-- Rating summary -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-8 text-center">
      <div>
        <div class="font-display text-5xl font-bold text-[var(--color-coral)]">4.9</div>
        <div class="flex justify-center gap-0.5 my-1">
          {Array.from({ length: 5 }, () => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-gold)" stroke="none">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
        <div class="text-[var(--color-charcoal-mid)] text-sm">Promedio de calificación</div>
      </div>
      <div class="w-px h-16 bg-[var(--color-cream-dark)] hidden sm:block" />
      <div>
        <div class="font-display text-5xl font-bold text-[var(--color-teal)]">500+</div>
        <div class="text-[var(--color-charcoal-mid)] text-sm mt-2">Reseñas verificadas</div>
      </div>
      <div class="w-px h-16 bg-[var(--color-cream-dark)] hidden sm:block" />
      <div>
        <div class="font-display text-5xl font-bold text-[var(--color-gold)]">98%</div>
        <div class="text-[var(--color-charcoal-mid)] text-sm mt-2">Volvería a viajar con Girlas</div>
      </div>
    </div>
  </div>
</section>
