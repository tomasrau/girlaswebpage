---
import TestimonialCard from '../ui/TestimonialCard.astro';
import { testimonials, getMetrics, getFeatured } from '../../data/testimonials';
import { pastDestinations } from '../../data/trips';

const metrics  = getMetrics(testimonials);
const featured = getFeatured(testimonials, 4);
const hasData  = testimonials.length > 0;

// URL del Google Apps Script Web App — configurar en:
// 1. Google Sheet → Extensiones → Apps Script → Implementar como aplicación web
// 2. Copiar la URL de implementación
// 3. Agregar como variable de repositorio APPS_SCRIPT_URL en GitHub
// 4. Agregar PUBLIC_APPS_SCRIPT_URL=<url> en tu .env local
const APPS_SCRIPT_URL = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';

---

<section class="section-padding bg-[var(--color-cream-dark)]" aria-labelledby="testimonials-title">
  <div class="container-girlas">

    <!-- Section header -->
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral)] text-sm font-medium tracking-widest uppercase">
          Lo que dicen ellas
        </span>
        <div class="w-10 h-px bg-[var(--color-coral)]" />
      </div>
      <h2 id="testimonials-title" class="font-display text-4xl lg:text-5xl font-bold text-[var(--color-charcoal)] mb-4">
        Historias reales,<br />
        <em class="text-gradient-coral not-italic">aventuras reales</em>
      </h2>
      <p class="text-[var(--color-charcoal-mid)] text-lg max-w-xl mx-auto">
        {hasData
          ? `${metrics.total} viajera${metrics.total !== 1 ? 's' : ''} ya compartió su experiencia.`
          : 'Sé parte de la comunidad y contá tu historia.'}
      </p>
    </div>

    <!-- Metrics strip — solo con datos reales -->
    {hasData && (
      <div class="grid grid-cols-3 gap-4 mb-14 max-w-2xl mx-auto">
        <!-- Avg stars -->
        <div class="text-center bg-white rounded-2xl p-5 shadow-[var(--shadow-card)]">
          <div class="font-display text-4xl font-bold text-[var(--color-gold)] mb-1">
            {metrics.avgStars}
          </div>
          <div class="flex justify-center gap-0.5 mb-1" aria-hidden="true">
            {Array.from({ length: 5 }, (_, i) => (
              <svg width="12" height="12" viewBox="0 0 24 24"
                fill={i < Math.round(metrics.avgStars) ? 'var(--color-gold)' : 'none'}
                stroke="var(--color-gold)" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
          <p class="text-[var(--color-charcoal-mid)] text-xs leading-snug">Calificación promedio</p>
        </div>

        <!-- Promoter rate -->
        <div class="text-center bg-white rounded-2xl p-5 shadow-[var(--shadow-card)]">
          <div class="font-display text-4xl font-bold mb-1 text-[var(--color-teal)] tabular-nums">
            {metrics.promoterPct}%
          </div>
          <p class="text-[var(--color-charcoal-mid)] text-xs leading-snug mt-3">La recomiendan</p>
        </div>

        <!-- Would return -->
        <div class="text-center bg-white rounded-2xl p-5 shadow-[var(--shadow-card)]">
          <div class="font-display text-4xl font-bold text-[var(--color-coral)] mb-1">
            {metrics.wouldReturnPct}%
          </div>
          <p class="text-[var(--color-charcoal-mid)] text-xs leading-snug mt-3">Volvería a viajar</p>
        </div>
      </div>
    )}

    <!-- Cards grid or empty state -->
    {hasData ? (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          {featured.map((t) => (
            <TestimonialCard
              name={t.name}
              instagramHandle={t.instagramHandle}
              stars={t.stars}
              nps={t.nps}
              wouldReturn={t.wouldReturn}
              text={t.text}
              trip={t.destination}
              date={t.date}
            />
          ))}
        </div>

        {testimonials.length > 4 && (
          <div class="text-center mb-10">
            <a
              href="/blog/#resenas"
              class="inline-flex items-center gap-2 text-[var(--color-coral)] font-semibold text-sm hover:gap-3 transition-all"
            >
              Ver todas las reseñas ({testimonials.length})
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        )}
      </>
    ) : (
      <!-- Empty state -->
      <div class="text-center py-12 mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[var(--color-coral)]/10 mb-6" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-coral)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3 class="font-display text-2xl font-semibold text-[var(--color-charcoal)] mb-3">
          Sé la primera en contar tu experiencia
        </h3>
        <p class="text-[var(--color-charcoal-mid)] max-w-md mx-auto leading-relaxed">
          Tu historia puede inspirar a otras mujeres a animarse a viajar. Solo tardás 2 minutos.
        </p>
      </div>
    )}

    <!-- CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <button
        id="open-review-modal"
        type="button"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[var(--color-coral)] text-white font-semibold text-base hover:bg-[var(--color-coral-dark)] shadow-lg hover:shadow-xl transition-all active:scale-95"
        aria-haspopup="dialog"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Contar mi experiencia
      </button>
      {hasData && testimonials.length <= 4 && (
        <a
          href="/blog/#resenas"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-[var(--color-charcoal)]/15 text-[var(--color-charcoal-mid)] font-semibold text-base hover:border-[var(--color-coral)] hover:text-[var(--color-coral)] transition-all"
        >
          Ver todas las reseñas
        </a>
      )}
    </div>

  </div>
</section>

<!-- ─── Modal / Dialog ──────────────────────────────────────────────────── -->
<dialog
  id="review-dialog"
  aria-labelledby="dialog-title"
  aria-modal="true"
  class="review-dialog"
>
  <!-- Backdrop click closes dialog -->
  <div class="dialog-backdrop" id="dialog-backdrop" aria-hidden="true"></div>

  <div class="dialog-panel" role="document">

    <!-- Header -->
    <div class="dialog-header">
      <div>
        <h2 id="dialog-title" class="font-display text-2xl font-bold text-[var(--color-charcoal)]">
          Contá tu experiencia
        </h2>
        <p class="text-[var(--color-charcoal-mid)] text-sm mt-1">
          Tu reseña ayuda a otras mujeres a animarse a viajar.
        </p>
      </div>
      <button
        id="close-review-modal"
        type="button"
        aria-label="Cerrar"
        class="close-btn"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Form -->
    <form
      id="review-form"
      novalidate
      class="dialog-form"
    >
      <!-- Hidden fields para Formspree -->
      <input type="hidden" name="_subject" value="Nueva reseña Girlas" />
      <input type="hidden" name="stars" id="hidden-stars" />
      <input type="hidden" name="nps" id="hidden-nps" />
      <input type="hidden" name="wouldReturn" id="hidden-would-return" />

      <!-- ── Grupo 1: Sobre vos ── -->
      <fieldset class="form-group">
        <legend class="form-legend">Sobre vos</legend>
        <div class="form-row">
          <div class="form-field">
            <label for="field-name" class="form-label">
              Tu nombre <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="field-name"
              name="name"
              autocomplete="given-name"
              placeholder="Ej: María G."
              required
              class="form-input"
            />
          </div>
          <div class="form-field">
            <label for="field-instagram" class="form-label">
              Tu @instagram <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
            </label>
            <div class="input-prefix-wrap">
              <span class="input-prefix" aria-hidden="true">@</span>
              <input
                type="text"
                id="field-instagram"
                name="instagram"
                autocomplete="username"
                placeholder="tuinstagram"
                required
                class="form-input with-prefix"
              />
            </div>
          </div>
        </div>
      </fieldset>

      <!-- ── Grupo 2: Tu viaje ── -->
      <fieldset class="form-group">
        <legend class="form-legend">Tu viaje</legend>
        <div class="form-field">
          <label for="field-destination" class="form-label">
            ¿A qué destino viajaste? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </label>
          <select
            id="field-destination"
            name="destination"
            required
            class="form-input"
          >
            <option value="" disabled selected>Seleccioná un destino</option>
            {pastDestinations.map(d => (
              <option value={d}>{d}</option>
            ))}
            <option value="Otro destino">Otro destino</option>
          </select>
        </div>

        <!-- Stars picker -->
        <div class="form-field">
          <span class="form-label" id="stars-label">
            Tu calificación <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div class="stars-picker" role="radiogroup" aria-labelledby="stars-label" aria-required="true" data-required="true">
            {[1, 2, 3, 4, 5].map(n => (
              <button
                type="button"
                data-value={n}
                class="star-btn"
                aria-label={`${n} estrella${n > 1 ? 's' : ''}`}
                aria-pressed="false"
              >
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </button>
            ))}
          </div>
          <p class="star-hint" id="stars-hint" aria-live="polite"></p>
        </div>
      </fieldset>

      <!-- ── Grupo 3: Tu opinión ── -->
      <fieldset class="form-group">
        <legend class="form-legend">Tu opinión</legend>

        <!-- NPS -->
        <div class="form-field">
          <span class="form-label" id="nps-label">
            ¿Cuánto recomendarías Girlas? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div
            class="nps-picker"
            role="radiogroup"
            aria-labelledby="nps-label"
            aria-required="true"
            data-required="true"
          >
            {Array.from({ length: 11 }, (_, i) => (
              <button
                type="button"
                data-value={i}
                class="nps-btn"
                aria-label={`${i} de 10`}
                aria-pressed="false"
              >
                {i}
              </button>
            ))}
          </div>
          <div class="nps-labels" aria-hidden="true">
            <span>No la recomendaría</span>
            <span>La recomendaría muchísimo</span>
          </div>
        </div>

        <!-- Would return -->
        <div class="form-field">
          <span class="form-label" id="return-label">
            ¿Volverías a viajar con Girlas? <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </span>
          <div class="return-picker" role="radiogroup" aria-labelledby="return-label" aria-required="true" data-required="true">
            <button type="button" data-value="si" class="return-btn" aria-pressed="false">
              Sí, seguro
            </button>
            <button type="button" data-value="talvez" class="return-btn" aria-pressed="false">
              Tal vez
            </button>
            <button type="button" data-value="no" class="return-btn" aria-pressed="false">
              Todavía no
            </button>
          </div>
        </div>
      </fieldset>

      <!-- ── Grupo 4: Tu historia ── -->
      <fieldset class="form-group">
        <legend class="form-legend">Tu historia</legend>
        <div class="form-field">
          <label for="field-text" class="form-label">
            Contanos tu experiencia <span class="text-[var(--color-coral)]" aria-hidden="true">*</span>
          </label>
          <textarea
            id="field-text"
            name="review"
            rows="4"
            required
            minlength="30"
            placeholder="¿Qué fue lo que más te gustó? ¿Cómo fue la experiencia en el grupo? ¿Qué le dirías a alguien que está por anotarse?"
            class="form-input resize-none"
          ></textarea>
          <p class="text-xs text-[var(--color-charcoal-mid)] mt-1 text-right">
            <span id="char-count">0</span> caracteres (mín. 30)
          </p>
        </div>
      </fieldset>

      <!-- Consent + Submit -->
      <div class="form-submit-area">
        <p class="text-xs text-[var(--color-charcoal-mid)] text-center max-w-sm mx-auto">
          Al enviar aceptás que tu nombre e Instagram puedan aparecer públicamente en el sitio de Girlas.
        </p>
        <button type="submit" id="submit-btn" class="submit-btn">
          <span class="submit-label">Enviar mi reseña</span>
          <span class="submit-spinner" aria-hidden="true"></span>
        </button>
        <p id="form-error" class="form-error" role="alert" aria-live="assertive"></p>
      </div>
    </form>

    <!-- Success state (hidden by default) -->
    <div id="review-success" class="review-success" aria-live="polite" hidden>
      <div class="success-icon" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <path d="M22 4 12 14.01l-3-3"/>
        </svg>
      </div>
      <h3 class="font-display text-2xl font-bold text-[var(--color-charcoal)] text-center">
        ¡Gracias por compartir!
      </h3>
      <p class="text-[var(--color-charcoal-mid)] text-center leading-relaxed">
        Tu reseña ya es parte de la comunidad Girlas y va a aparecer en el sitio en unos minutos.
      </p>
      <button type="button" id="close-success" class="submit-btn" style="background:var(--color-teal)">
        Cerrar
      </button>
    </div>

  </div>
</dialog>

<!-- ─── Styles ──────────────────────────────────────────────────────────── -->
<style>
  /* ── Dialog overlay ── */
  .review-dialog {
    position: fixed;
    inset: 0;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    border: none;
    background: transparent;
    overflow: hidden;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }
  .review-dialog[open] {
    display: flex;
  }

  .dialog-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(38, 35, 34, 0.6);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  /* ── Panel ── */
  .dialog-panel {
    position: relative;
    z-index: 1;
    background: #fff;
    border-radius: 1.5rem;
    width: min(560px, calc(100vw - 2rem));
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    box-shadow: 0 24px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
    overscroll-behavior: contain;
  }

  /* ── Header ── */
  .dialog-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--color-cream-dark);
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 2;
    border-radius: 1.5rem 1.5rem 0 0;
  }

  .close-btn {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream-dark);
    color: var(--color-charcoal-mid);
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .close-btn:hover { background: var(--color-coral); color: #fff; }
  .close-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 2px; }

  /* ── Form ── */
  .dialog-form {
    padding: 1.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .form-group {
    border: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }
  .form-legend {
    font-family: var(--font-display, 'Ojuju', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-charcoal-mid);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-cream-dark);
    display: block;
    width: 100%;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .form-field:last-child { margin-bottom: 0; }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-charcoal);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .form-input {
    width: 100%;
    padding: 0.65rem 0.875rem;
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 0.625rem;
    font-size: 0.9375rem;
    font-family: var(--font-body, 'Poppins', sans-serif);
    color: var(--color-charcoal);
    background: var(--color-cream);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }
  .form-input:focus {
    border-color: var(--color-coral);
    box-shadow: 0 0 0 3px rgba(247, 168, 200, 0.25);
    background: #fff;
  }
  .form-input.error { border-color: #e74c3c; }
  .form-input::placeholder { color: var(--color-charcoal-mid); opacity: 0.6; }

  .input-prefix-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-prefix {
    position: absolute;
    left: 0.875rem;
    color: var(--color-coral);
    font-weight: 600;
    font-size: 0.9375rem;
    pointer-events: none;
    z-index: 1;
  }
  .form-input.with-prefix { padding-left: 1.875rem; }

  /* ── Star picker ── */
  .stars-picker {
    display: flex;
    gap: 0.25rem;
  }
  .star-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.125rem;
    border-radius: 0.25rem;
    transition: transform 0.1s;
    line-height: 0;
  }
  .star-btn:hover { transform: scale(1.15); }
  .star-btn[aria-pressed="true"] svg,
  .star-btn.hovered svg { fill: var(--color-gold); }
  .star-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 2px; border-radius: 4px; }

  .star-hint {
    font-size: 0.8125rem;
    color: var(--color-coral);
    min-height: 1.2em;
    margin-top: 0.25rem;
  }

  /* ── NPS picker ── */
  .nps-picker {
    display: flex;
    gap: 0.25rem;
    flex-wrap: nowrap;
  }
  .nps-btn {
    flex: 1;
    min-width: 0;
    aspect-ratio: 1;
    background: var(--color-cream-dark);
    border: 1.5px solid transparent;
    border-radius: 0.5rem;
    font-family: var(--font-display, 'Ojuju', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-charcoal-mid);
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .nps-btn:hover {
    background: var(--color-coral);
    color: #fff;
  }
  .nps-btn[aria-pressed="true"] {
    background: var(--color-coral);
    border-color: var(--color-coral-dark);
    color: #fff;
  }
  .nps-btn[data-value="9"][aria-pressed="true"],
  .nps-btn[data-value="10"][aria-pressed="true"] {
    background: var(--color-teal);
    border-color: var(--color-teal);
  }
  .nps-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 2px; }

  .nps-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.375rem;
    font-size: 0.6875rem;
    color: var(--color-charcoal-mid);
  }

  /* ── Would return ── */
  .return-picker {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .return-btn {
    flex: 1;
    min-width: 100px;
    padding: 0.625rem 1rem;
    border-radius: 9999px;
    border: 1.5px solid var(--color-cream-dark);
    background: var(--color-cream-dark);
    color: var(--color-charcoal-mid);
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-body, 'Poppins', sans-serif);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  .return-btn:hover {
    border-color: var(--color-coral);
    color: var(--color-coral);
    background: var(--color-coral)/5;
  }
  .return-btn[aria-pressed="true"] {
    background: var(--color-coral);
    border-color: var(--color-coral);
    color: #fff;
  }
  .return-btn[data-value="si"][aria-pressed="true"] {
    background: var(--color-teal);
    border-color: var(--color-teal);
  }
  .return-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 2px; }

  /* ── Submit area ── */
  .form-submit-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-cream-dark);
    margin-top: 0.5rem;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.9rem 2rem;
    border-radius: 9999px;
    background: var(--color-coral);
    color: #fff;
    font-family: var(--font-body, 'Poppins', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    box-shadow: 0 4px 14px rgba(247, 168, 200, 0.4);
  }
  .submit-btn:hover { background: var(--color-coral-dark); }
  .submit-btn:active { transform: scale(0.98); }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .submit-btn:focus-visible { outline: 2px solid var(--color-coral); outline-offset: 3px; }

  .submit-spinner {
    display: none;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 9999px;
    animation: spin 0.7s linear infinite;
  }
  .submit-btn.loading .submit-label { display: none; }
  .submit-btn.loading .submit-spinner { display: block; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-error {
    color: #e74c3c;
    font-size: 0.8125rem;
    text-align: center;
    min-height: 1em;
  }

  /* ── Success state ── */
  .review-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem 2rem;
  }
  .success-icon {
    width: 80px;
    height: 80px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-teal) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<!-- ─── Script ──────────────────────────────────────────────────────────── -->
<script is:inline define:vars={{ APPS_SCRIPT_URL }}>

  const dialog       = document.getElementById('review-dialog');
  const openBtn      = document.getElementById('open-review-modal');
  const closeBtn     = document.getElementById('close-review-modal');
  const backdrop     = document.getElementById('dialog-backdrop');
  const form         = document.getElementById('review-form');
  const successPanel = document.getElementById('review-success');
  const closeSuccess = document.getElementById('close-success');
  const submitBtn    = document.getElementById('submit-btn');
  const formError    = document.getElementById('form-error');
  const charCount    = document.getElementById('char-count');
  const textarea     = document.getElementById('field-text');

  // ── Open / close ──
  function openDialog() {
    dialog.showModal();
    document.body.style.overflow = 'hidden';
    setTimeout(() => closeBtn?.focus(), 50);
  }

  function closeDialog() {
    dialog.close();
    document.body.style.overflow = '';
    openBtn?.focus();
  }

  openBtn?.addEventListener('click', openDialog);
  closeBtn?.addEventListener('click', closeDialog);
  closeSuccess?.addEventListener('click', closeDialog);
  backdrop?.addEventListener('click', closeDialog);

  dialog?.addEventListener('cancel', (e) => {
    e.preventDefault();
    closeDialog();
  });

  // ── Star picker ──
  const starBtns  = document.querySelectorAll('.star-btn');
  const starHint  = document.getElementById('stars-hint');
  const hiddenStars = document.getElementById('hidden-stars');
  const starLabels  = ['', 'Malo', 'Regular', 'Bueno', 'Muy bueno', 'Excelente'];

  let selectedStars = 0;

  starBtns.forEach((btn) => {
    const val = parseInt(btn.dataset.value);

    btn.addEventListener('mouseenter', () => highlightStars(val));
    btn.addEventListener('mouseleave', () => highlightStars(selectedStars));
    btn.addEventListener('click', () => {
      selectedStars = val;
      hiddenStars.value = val;
      highlightStars(val, true);
      if (starHint) starHint.textContent = starLabels[val] || '';
    });
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        btn.click();
      }
    });
  });

  function highlightStars(upTo, persist = false) {
    starBtns.forEach((b) => {
      const v = parseInt(b.dataset.value);
      const filled = v <= upTo;
      b.querySelector('svg').setAttribute('fill', filled ? 'var(--color-gold)' : 'none');
      if (persist) b.setAttribute('aria-pressed', v <= upTo ? 'true' : 'false');
    });
  }

  // ── NPS picker ──
  const npsBtns    = document.querySelectorAll('.nps-btn');
  const hiddenNps  = document.getElementById('hidden-nps');

  npsBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      npsBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      hiddenNps.value = btn.dataset.value;
    });
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); btn.click(); }
    });
  });

  // ── Would-return picker ──
  const returnBtns       = document.querySelectorAll('.return-btn');
  const hiddenWouldReturn = document.getElementById('hidden-would-return');

  returnBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      returnBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      hiddenWouldReturn.value = btn.dataset.value;
    });
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); btn.click(); }
    });
  });

  // ── Char counter ──
  textarea?.addEventListener('input', () => {
    charCount.textContent = textarea.value.length;
  });

  // ── Validation ──
  function validate() {
    const name = document.getElementById('field-name').value.trim();
    const ig   = document.getElementById('field-instagram').value.trim();
    const dest = document.getElementById('field-destination').value;
    const text = textarea.value.trim();

    if (!name) return 'Por favor ingresá tu nombre.';
    if (!ig)   return 'Tu @instagram es obligatorio para verificar la reseña.';
    if (!dest) return 'Por favor seleccioná un destino.';
    if (!hiddenStars.value) return 'Por favor seleccioná una calificación.';
    if (!hiddenNps.value) return 'Por favor indicá tu NPS (0-10).';
    if (!hiddenWouldReturn.value) return '¿Volverías a viajar con Girlas?';
    if (text.length < 30) return `Contanos un poco más (${30 - text.length} caracteres más).`;
    return null;
  }

  // ── Submit ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.textContent = '';

    const err = validate();
    if (err) { formError.textContent = err; return; }

    if (!APPS_SCRIPT_URL) {
      formError.textContent = 'El formulario no está configurado aún. Escribinos por WhatsApp.';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    try {
      const payload = new URLSearchParams({
        name:        document.getElementById('field-name').value.trim(),
        instagram:   document.getElementById('field-instagram').value.trim(),
        destination: document.getElementById('field-destination').value,
        stars:       hiddenStars.value,
        nps:         hiddenNps.value,
        wouldReturn: hiddenWouldReturn.value,
        review:      textarea.value.trim(),
      });

      const res  = await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        body: payload,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      });

      const body = await res.json().catch(() => ({}));

      if (body?.ok) {
        form.hidden = true;
        successPanel.hidden = false;
      } else {
        formError.textContent =
          body?.error ||
          'Hubo un error al enviar. Intentá de nuevo o escribinos por WhatsApp.';
        submitBtn.disabled = false;
        submitBtn.classList.remove('loading');
      }
    } catch {
      formError.textContent = 'Error de conexión. Revisá tu internet e intentá de nuevo.';
      submitBtn.disabled = false;
      submitBtn.classList.remove('loading');
    }
  });

  // Reset form on close
  dialog?.addEventListener('close', () => {
    form.reset();
    form.hidden = false;
    successPanel.hidden = true;
    submitBtn.disabled = false;
    submitBtn.classList.remove('loading');
    formError.textContent = '';
    selectedStars = 0;
    hiddenStars.value = '';
    hiddenNps.value = '';
    hiddenWouldReturn.value = '';
    if (starHint) starHint.textContent = '';
    if (charCount) charCount.textContent = '0';
    highlightStars(0);
    npsBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
    returnBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
  });
</script>
