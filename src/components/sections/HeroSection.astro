---
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  backgroundImage?: string;
  height?: 'full' | 'large' | 'medium';
}

const {
  title,
  subtitle,
  ctaPrimary = { label: 'Ver experiencias', href: '/experiencias' },
  ctaSecondary = { label: 'Conocenos', href: '/nosotras' },
  backgroundImage = '/images/hero-bkg-1920.jpg',
  height = 'full',
} = Astro.props;

const heights = {
  full:   'min-h-screen',
  large:  'min-h-[80vh]',
  medium: 'min-h-[60vh]',
};
---

<section
  class={`relative flex items-center ${heights[height]} overflow-hidden`}
  aria-label="Sección principal"
>
  <!-- Background image with overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      srcset="/images/hero-bkg-800.jpg 800w, /images/hero-bkg-1280.jpg 1280w, /images/hero-bkg-1920.jpg 1920w"
      sizes="100vw"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1080"
    />
    <!-- Gradient overlay: dark left for text, transparent right -->
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-charcoal)]/80 via-[var(--color-charcoal)]/50 to-transparent" />
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--color-cream)] to-transparent" />
  </div>

  <!-- Decorative dots pattern -->
  <div class="absolute top-20 right-10 w-64 h-64 opacity-10 z-0" aria-hidden="true">
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      {Array.from({ length: 10 }, (_, row) =>
        Array.from({ length: 10 }, (_, col) => (
          <circle cx={col * 20 + 10} cy={row * 20 + 10} r="2.5" fill="white" />
        ))
      )}
    </svg>
  </div>

  <!-- Content -->
  <div class="container-girlas relative z-10 py-24 pt-36">
    <div class="max-w-2xl">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-px bg-[var(--color-coral)]" />
        <span class="text-[var(--color-coral-light)] text-sm font-medium tracking-widest uppercase font-body">
          Viajes & Experiencias
        </span>
      </div>

      <!-- Headline -->
      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
        {title}
      </h1>

      {subtitle && (
        <p class="text-white/75 text-lg sm:text-xl leading-relaxed mb-10 max-w-lg">
          {subtitle}
        </p>
      )}

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href={ctaPrimary.href}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[var(--color-coral)] text-white font-semibold text-base hover:bg-[var(--color-coral-dark)] shadow-lg hover:shadow-xl transition-all active:scale-95"
        >
          {ctaPrimary.label}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href={ctaSecondary.href}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-white/50 text-white font-semibold text-base hover:bg-white/10 transition-all active:scale-95"
        >
          {ctaSecondary.label}
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap gap-6 mt-12">
        {[
          { number: '500+', label: 'Viajeras' },
          { number: '30+', label: 'Destinos' },
          { number: '5★', label: 'Calificación' },
        ].map(({ number, label }) => (
          <div class="flex flex-col">
            <span class="font-display text-2xl font-bold text-white">{number}</span>
            <span class="text-white/60 text-xs tracking-wide uppercase">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</section>
