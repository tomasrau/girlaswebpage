---
const year = new Date().getFullYear();

const links = {
  experiencias: [
    { href: '/experiencias', label: 'Todas las experiencias' },
    { href: '/experiencias#viajes-grupales', label: 'Viajes grupales' },
    { href: '/experiencias#retiros', label: 'Retiros de bienestar' },
    { href: '/experiencias#aventura', label: 'Aventura y naturaleza' },
  ],
  empresa: [
    { href: '/nosotras', label: 'Nosotras' },
    { href: '/blog', label: 'Blog' },
    { href: '/galeria', label: 'Galería' },
    { href: '/contacto', label: 'Contacto' },
  ],
};

const socials = [
  { href: 'https://instagram.com/girlas.ar', label: 'Instagram', icon: 'instagram' },
  { href: 'https://wa.me/5492944675892', label: 'WhatsApp', icon: 'whatsapp' },
];
---

<footer class="bg-[var(--color-charcoal)] text-white">
  <!-- Main footer -->
  <div class="container-girlas py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-4">
          <img
            src="/logos/logo-girlas-full.png"
            alt="Girlas"
            class="h-14 w-auto opacity-90 hover:opacity-100 transition-opacity brightness-0 invert"
            width="180"
            height="56"
          />
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs mb-6">
          Viajes y experiencias diseñadas para el mundo femenino. Aventura, conexión y libertad desde Argentina para el mundo.
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          {socials.map(({ href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-[var(--color-rosa)] hover:bg-[var(--color-rosa)]/10 transition-all"
            >
              {label === 'Instagram' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="m16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              )}
{label === 'WhatsApp' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Experiencias -->
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">
          Experiencias
        </h3>
        <ul class="flex flex-col gap-2.5">
          {links.experiencias.map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/60 hover:text-white text-sm transition-colors link-underline">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">
          Empresa
        </h3>
        <ul class="flex flex-col gap-2.5">
          {links.empresa.map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/60 hover:text-white text-sm transition-colors link-underline">
                {label}
              </a>
            </li>
          ))}
        </ul>

        <!-- WhatsApp CTA -->
        <div class="mt-8 p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-xs text-white/50 mb-2">¿Dudas? Escribinos</p>
          <a
            href="https://wa.me/5492944675892"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-rosa)] text-sm font-medium hover:text-white transition-colors"
          >
            +54 929 4467-5892 →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-girlas py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-xs">
        © {year} Girlas. Todos los derechos reservados.
      </p>
      <div class="flex gap-4">
        <a href="/privacidad" class="text-white/40 hover:text-white/70 text-xs transition-colors">
          Política de privacidad
        </a>
        <a href="/terminos" class="text-white/40 hover:text-white/70 text-xs transition-colors">
          Términos y condiciones
        </a>
      </div>
    </div>
  </div>
</footer>
