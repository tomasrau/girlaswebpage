---
interface Props {
  name: string;
  instagramHandle?: string;
  location?: string;
  text: string;
  avatar?: string;
  stars: number;
  nps?: number;
  wouldReturn?: 'si' | 'talvez' | 'no';
  trip?: string;
  date?: string;
}

const {
  name,
  instagramHandle,
  location,
  text,
  avatar,
  stars = 5,
  nps,
  wouldReturn,
  trip,
  date,
} = Astro.props;

const wouldReturnConfig = {
  si:     { label: '✓ Volvería',       cls: 'text-[var(--color-teal)] bg-[var(--color-teal)]/10' },
  talvez: { label: '~ Tal vez',         cls: 'text-[var(--color-gold)] bg-[var(--color-gold)]/10' },
  no:     { label: '✗ No por ahora',    cls: 'text-[var(--color-charcoal-mid)] bg-[var(--color-cream-dark)]' },
};

const igHandle = instagramHandle?.replace('@', '');

const formattedDate = date
  ? new Date(date).toLocaleDateString('es-AR', { month: 'long', year: 'numeric' })
  : undefined;
---

<blockquote class="relative bg-white rounded-[var(--radius-card)] p-6 shadow-[var(--shadow-card)] flex flex-col gap-4 h-full">
  <!-- Background quote mark -->
  <div class="absolute top-5 right-5 text-[var(--color-coral)]/10 pointer-events-none" aria-hidden="true">
    <svg width="44" height="44" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
    </svg>
  </div>

  <!-- Stars + NPS -->
  <div class="flex items-center gap-3 flex-wrap">
    <div class="flex gap-0.5" aria-label={`${stars} de 5 estrellas`}>
      {Array.from({ length: 5 }, (_, i) => (
        <svg width="15" height="15" viewBox="0 0 24 24"
          fill={i < stars ? 'var(--color-gold)' : 'none'}
          stroke="var(--color-gold)" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          aria-hidden="true">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      ))}
    </div>
    {nps !== undefined && (
      <span class="text-xs text-[var(--color-charcoal-mid)] bg-[var(--color-cream-dark)] px-2 py-0.5 rounded-full">
        NPS {nps}/10
      </span>
    )}
  </div>

  <!-- Review text -->
  <p class="text-[var(--color-charcoal-mid)] text-[0.9375rem] leading-relaxed italic flex-1">
    "{text}"
  </p>

  <!-- Tags -->
  {(trip || wouldReturn) && (
    <div class="flex flex-wrap gap-2">
      {trip && (
        <span class="text-xs font-medium text-[var(--color-coral)] bg-[var(--color-coral)]/8 px-2.5 py-1 rounded-full">
          {trip}
        </span>
      )}
      {wouldReturn && (
        <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${wouldReturnConfig[wouldReturn].cls}`}>
          {wouldReturnConfig[wouldReturn].label}
        </span>
      )}
    </div>
  )}

  <!-- Author -->
  <footer class="flex items-center gap-3 pt-4 border-t border-[var(--color-cream-dark)]">
    {avatar ? (
      <img src={avatar} alt={`Foto de ${name}`}
        class="w-10 h-10 rounded-full object-cover ring-2 ring-[var(--color-cream-dark)] shrink-0"
        loading="lazy" width="40" height="40" />
    ) : (
      <div
        class="w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-coral)] to-[var(--color-coral-dark)] flex items-center justify-center text-white font-display font-bold text-base shrink-0"
        aria-hidden="true">
        {name.charAt(0)}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <cite class="not-italic font-semibold text-[var(--color-charcoal)] text-sm block truncate">{name}</cite>
      {igHandle ? (
        <a
          href={`https://instagram.com/${igHandle}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-coral)] text-xs hover:underline"
          aria-label={`Ver perfil de Instagram de ${name}`}
        >
          @{igHandle}
        </a>
      ) : location ? (
        <p class="text-[var(--color-charcoal-mid)] text-xs truncate">{location}</p>
      ) : null}
    </div>
    {formattedDate && (
      <time class="text-xs text-[var(--color-charcoal-mid)] shrink-0 capitalize">
        {formattedDate}
      </time>
    )}
  </footer>
</blockquote>
