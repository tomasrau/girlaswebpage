---
interface Props {
  title: string;
  destination: string;
  duration: string;
  price: string;
  image: string;
  imagePosition?: string;
  tags?: string[];
  href?: string;
  featured?: boolean;
  soldOut?: boolean;
  comingSoon?: boolean;
  past?: boolean;
  dateStart?: string;
  dateEnd?: string;
}

const {
  title,
  destination,
  duration,
  price,
  image,
  imagePosition = 'center',
  tags = [],
  href = '#',
  featured = false,
  soldOut = false,
  comingSoon = false,
  past = false,
  dateStart,
  dateEnd,
} = Astro.props;

const WA_NUMBER = '5492944675892';
const waNextTrip = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent('Hola! Quiero sumarme al próximo viaje a ' + title)}`;

const dateLabel = dateStart
  ? (dateEnd ? `${dateStart} – ${dateEnd}` : dateStart)
  : null;
const showDateBadge = !!dateLabel;
const showSoonBadge = !soldOut && !past && !dateLabel && comingSoon;
---

<article
  class:list={[
    'group relative rounded-[var(--radius-card)] overflow-hidden bg-white shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-hover)] transition-all duration-300 hover:-translate-y-1 flex flex-col h-full',
    featured && !soldOut && !past ? 'ring-2 ring-[var(--color-coral)]' : '',
    soldOut || past ? 'ring-2 ring-[var(--color-charcoal)]/30' : '',
  ]}
>
  {featured && !soldOut && !past && (
    <div class="absolute top-4 left-4 z-10">
      <span class="px-3 py-1 rounded-full bg-[var(--color-coral)] text-white text-xs font-semibold tracking-wide">
        ✦ Destacado
      </span>
    </div>
  )}

  {past && (
    <div class="absolute top-4 left-4 z-10">
      <span class="px-3 py-1 rounded-full bg-[var(--color-charcoal)]/75 backdrop-blur-sm text-white text-xs font-semibold tracking-wide">
        ✓ Vivida
      </span>
    </div>
  )}

  <!-- Image -->
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={image}
      alt={`Experiencia: ${title} en ${destination}`}
      class:list={[
        'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
        soldOut ? 'brightness-[0.55] saturate-[0.4]' : '',
      ]}
      style={`object-position: ${imagePosition}${past ? '; filter: grayscale(22%) brightness(0.92)' : ''}`}
      loading="lazy"
    />

    {!soldOut && !past && (
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
    )}

    {past && (
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-60" />
    )}

    {showDateBadge && (
      <div class="absolute bottom-3 left-3 z-20">
        <span class="inline-flex items-center gap-1.5 bg-black/55 backdrop-blur-sm text-white text-xs font-semibold rounded-full px-3 py-1.5 leading-none tracking-wide">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {dateLabel}
        </span>
      </div>
    )}

    {showSoonBadge && (
      <div class="absolute bottom-3 left-3 z-10">
        <span class="inline-flex items-center gap-1.5 bg-[var(--color-coral)]/80 backdrop-blur-sm text-white text-xs font-semibold rounded-full px-3 py-1.5 leading-none tracking-wide">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Fechas próximamente
        </span>
      </div>
    )}

    {soldOut && (
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 select-none">
        <div class="relative">
          <div class="sold-out-stamp">
            <span class="sold-out-line1">SOLD</span>
            <span class="sold-out-line2">OUT</span>
          </div>
        </div>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <span class:list={[
            'px-2.5 py-0.5 rounded-full text-xs font-medium',
            past
              ? 'bg-[var(--color-charcoal)]/8 text-[var(--color-charcoal-mid)]/70'
              : 'bg-[var(--color-cream-dark)] text-[var(--color-charcoal-mid)]',
          ]}>
            {tag}
          </span>
        ))}
      </div>
    )}

    <h3 class:list={[
      'font-display text-xl font-semibold mb-1 leading-snug',
      past ? 'text-[var(--color-charcoal)]/70' : 'text-[var(--color-charcoal)]',
    ]}>
      {title}
    </h3>

    <div class="flex items-center gap-1 text-[var(--color-charcoal-mid)] text-sm mb-4">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
      </svg>
      {destination}
    </div>

    <div class="mt-auto">
    <div class="flex items-center justify-between pt-4 border-t border-[var(--color-cream-dark)]">
      <div class="flex items-center gap-4 text-sm text-[var(--color-charcoal-mid)]">
        <span class="flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {duration}
        </span>
      </div>
      <div class="text-right">
        {past ? (
          <span class="text-xs text-[var(--color-charcoal-mid)]/60 font-medium tracking-wide uppercase">Experiencia realizada</span>
        ) : (
          <>
            <span class="font-display text-xl font-bold text-[var(--color-coral)]">{price}</span>
            <span class="text-xs text-[var(--color-charcoal-mid)] block">por persona</span>
          </>
        )}
      </div>
    </div>

    {soldOut && !past ? (
      <div class="mt-4 flex items-center justify-center gap-2 w-full py-2.5 rounded-full bg-[var(--color-charcoal)]/8 border-2 border-[var(--color-charcoal)]/20 text-[var(--color-charcoal)]/40 text-sm font-semibold cursor-not-allowed">
        Agotado
      </div>
    ) : past ? (
      <a
        href={waNextTrip}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 flex items-center justify-center gap-2 w-full py-2.5 rounded-full border-2 border-[var(--color-charcoal)]/25 text-[var(--color-charcoal)]/60 text-sm font-semibold hover:border-[var(--color-coral)] hover:text-[var(--color-coral)] transition-all"
      >
        Sumáte al próximo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    ) : (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 flex items-center justify-center gap-2 w-full py-2.5 rounded-full border-2 border-[var(--color-coral)] text-[var(--color-coral)] text-sm font-semibold hover:bg-[var(--color-coral)] hover:text-white transition-all"
      >
        Para más info
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    )}
    </div><!-- /mt-auto -->
  </div>
</article>

<style>
  .sold-out-stamp {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.6rem;
    border: 3px solid rgba(255,255,255,0.85);
    border-radius: 6px;
    transform: rotate(-12deg);
    box-shadow: 0 2px 16px rgba(0,0,0,0.35), inset 0 0 0 1px rgba(255,255,255,0.1);
    background: rgba(0,0,0,0.18);
    backdrop-filter: blur(2px);
    gap: 0;
    line-height: 1;
  }
  .sold-out-line1,
  .sold-out-line2 {
    font-family: var(--font-display, 'Ojuju', sans-serif);
    font-size: 2.1rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.92);
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    display: block;
  }
</style>
