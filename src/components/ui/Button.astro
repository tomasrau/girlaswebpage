---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit';
  disabled?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
  type = 'button',
  disabled = false,
} = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 font-body font-semibold rounded-full transition-all duration-200 active:scale-95 focus-visible:outline-2 focus-visible:outline-offset-2';

const variants = {
  primary:   'bg-[var(--color-coral)] text-white hover:bg-[var(--color-coral-dark)] shadow-md hover:shadow-lg focus-visible:outline-[var(--color-coral)]',
  secondary: 'bg-[var(--color-teal)] text-white hover:bg-[var(--color-teal-dark)] shadow-md hover:shadow-lg focus-visible:outline-[var(--color-teal)]',
  outline:   'border-2 border-[var(--color-coral)] text-[var(--color-coral)] hover:bg-[var(--color-coral)] hover:text-white focus-visible:outline-[var(--color-coral)]',
  ghost:     'text-[var(--color-coral)] hover:bg-[var(--color-coral)]/10 focus-visible:outline-[var(--color-coral)]',
};

const sizes = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-7 py-3 text-base',
  lg: 'px-9 py-4 text-lg',
};

const classes = [base, variants[variant], sizes[size], className].join(' ');
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled}>
    <slot />
  </button>
)}
